
{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".indexOn": ["role"],
      "$uid": {
        ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "stores": {
      ".read": "auth != null",
      "$storeId": {
        ".write": "auth != null && (!data.exists() || data.child('ownerId').val() === auth.uid)"
      }
    },
    "storeMembers": {
      ".read": "auth != null",
      "$storeId": {
        ".write": "root.child('stores').child($storeId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        "$uid": {
          ".write": "auth.uid === $uid"
        }
      }
    },
    "storeData": {
      "$storeId": {
        ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
        ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
        "products": {
          ".indexOn": ["category", "group", "barcode"]
        },
        "orders": {
          ".indexOn": "customerId"
        },
        "cashTransactions": {
          ".indexOn": ["createdAt", "reference", "transactionDate"]
        },
        "expenses": {
          ".indexOn": "date"
        },
        "collections": {
          ".indexOn": "customerId"
        }
      }
    },
    "activityLogs": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": "timestamp"
    }
  }
}
