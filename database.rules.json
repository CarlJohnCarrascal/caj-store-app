{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "products": {
      ".indexOn": ["category", "group"]
    },
    "orders": {
      ".indexOn": "customerId"
    },
    "cashTransactions": {
      ".indexOn": ["createdAt", "reference", "transactionDate"]
    },
    "expenses": {
      ".indexOn": "date"
    },
    "collections": {
      ".indexOn": "customerId"
    },
    "activityLogs": {
      ".indexOn": "timestamp"
    },
    "users": {
        ".indexOn": ["role"]
    }
  }
}
