
{
  "rules": {
    "users": {
      ".indexOn": ["role"],
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "stores": {
      ".read": "auth != null",
      "$storeId": {
        ".write": "auth != null && (!data.exists() || data.child('ownerId').val() === auth.uid)"
      }
    },
    "storeMembers": {
      ".read": "auth != null",
      "$storeId": {
        ".write": "root.child('stores').child($storeId).child('ownerId').val() === auth.uid",
        "$uid": {
          ".write": "auth.uid === $uid"
        }
      }
    },
    "storeData": {
      "$storeId": {
        "products": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".indexOn": ["category", "group", "barcode"]
        },
        "orders": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".indexOn": "customerId"
        },
        "cashTransactions": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".indexOn": ["createdAt", "reference", "transactionDate"]
        },
        "expenses": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".indexOn": "date"
        },
        "collections": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".indexOn": "customerId"
        },
        "accounts": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "feeThresholds": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "printingPrices": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "salesReports": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "productReports": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "customerReports": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "cashIOReports": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "eloadingReports": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "printingReports": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        },
        "otherServiceReports": {
          ".read": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'",
          ".write": "auth != null && root.child('storeMembers').child($storeId).child(auth.uid).child('status').val() === 'approved'"
        }
      }
    },
    "activityLogs": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": "timestamp"
    }
  }
}
